# =============================================================================
# ANSIBLE INVENTORY - Template
# =============================================================================
# Copy file này thành hosts.ini và điền IP từ Terraform outputs:
# cp hosts.ini.example hosts.ini
# 
# Lấy IP từ: terraform output -json
# =============================================================================

[sonarqube]
sonarqube ansible_host=SONARQUBE_PUBLIC_IP ansible_user=ubuntu ansible_python_interpreter=/usr/bin/python3

[database]
db-nfs ansible_host=DB_NFS_PUBLIC_IP ansible_user=ubuntu ansible_python_interpreter=/usr/bin/python3

[nfs_server]
db-nfs ansible_host=DB_NFS_PUBLIC_IP ansible_user=ubuntu ansible_python_interpreter=/usr/bin/python3

[all:vars]
ansible_ssh_common_args='-o StrictHostKeyChecking=no'

# =============================================================================
# VARIABLES - Điền sau khi Terraform deploy
# =============================================================================
# NFS_SERVER_PRIVATE_IP=DB_NFS_PRIVATE_IP  # Dùng cho K8s PersistentVolume
