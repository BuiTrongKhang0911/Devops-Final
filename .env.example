# =============================================================================
# .ENV.EXAMPLE - Cấu hình môi trường (Copy thành .env và điền giá trị)
# =============================================================================

# Tên SSH Key trên AWS (KHÔNG có đuôi .pem)
# Phải khớp với key đã tạo trên AWS Console và file .pem trong project
AWS_KEY_NAME=your-key-name-here

# Database Password (dùng cho PostgreSQL và GitHub Actions Secret)
# Password này sẽ được dùng để:
# - Tạo user PostgreSQL trên DB server
# - Cấu hình trong GitHub Actions Secret DB_PASSWORD
DB_PASSWORD=SecurePassword123!

# =============================================================================
# HTTPS CONFIGURATION (Để trống nếu chưa có domain)
# =============================================================================
# Domain name của bạn (VD: example.com)
DOMAIN_NAME=

# Bật HTTPS (true/false)
ENABLE_HTTPS=false

# =============================================================================
# ALERTMANAGER EMAIL NOTIFICATION (Optional - để trống nếu không dùng)
# =============================================================================
# Email để nhận alerts từ Alertmanager
# Nếu để trống, alerts chỉ hiển thị trong UI (không gửi email)
ALERT_EMAIL=

# Gmail App Password (KHÔNG phải password thường!)
# Tạo App Password tại: https://myaccount.google.com/apppasswords
# Yêu cầu: Bật 2-Step Verification trước
# ⚠️  QUAN TRỌNG: XÓA TẤT CẢ KHOẢNG TRẮNG! (VD: iuowcnphxwwcdjhf)
ALERT_EMAIL_PASSWORD=
