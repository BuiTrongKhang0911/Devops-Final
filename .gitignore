*.pem
*.key
*.ppk
*.p12
*.pfx

# Node modules - Frontend dependencies & build artifacts
frontend/node_modules/
frontend/dist/
frontend/build/
**/node_modules/
**/dist/
**/build/
package-lock.json
yarn.lock

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
*.iml
.vscode/

# Logs
*.log
npm-debug.log*

# Uploads (file thực tế — chỉ giữ .gitkeep)
uploads/*
!uploads/.gitkeep

# Docker
.dockerignore
