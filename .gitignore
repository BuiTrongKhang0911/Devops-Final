**/application.properties
!**/application.properties.example

# Security - Private keys & certificates
*.pem
*.key
*.ppk
*.p12
*.pfx

# Node modules
frontend/node_modules/
frontend/dist/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
*.iml
.vscode/

# Logs
*.log
npm-debug.log*

# Uploads (file thực tế — chỉ giữ .gitkeep)
uploads/*
!uploads/.gitkeep

# Docker
.dockerignore
